  "productName": "MedicalViewerApp",
  "mainBinaryName": "MedicalViewerApp",
  "version": "0.1.0",
  "identifier": "trame.slicer",
  "plugins": {},
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "Medical Viewer App",
        "width": 800,
        "visible": false,
        "useHttpsScheme": true
      },
      {
        "label": "splashscreen",
        "width": 400,
        "height": 200,
        "center": true,
        "decorations": false,
        "resizable": false,
        "visible": true,
        "alwaysOnTop": true,
        "url": "splashscreen.html",
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' ws: localhost; script-src 'unsafe-eval' 'self';; connect-src ipc: http://ipc.localhost"
    }
  }
